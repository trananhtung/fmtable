{
  "name": "fmtable",
  "version": "0.1.0",
  "description": "Zero-dependency ASCII/Unicode table formatter — plain, grid, rounded, pipe/Markdown, and minimal styles, per-column alignment, auto-width.",
  "keywords": [
    "table",
    "ascii-table",
    "cli-table",
    "tabulate",
    "format",
    "terminal",
    "console",
    "markdown-table",
    "unicode-table"
  ],
  "homepage": "https://github.com/trananhtung/fmtable#readme",
  "bugs": {
    "url": "https://github.com/trananhtung/fmtable/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trananhtung/fmtable.git"
  },
  "license": "MIT",
  "author": "trananhtung",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fmtable": "./dist/bin/fmtable.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
